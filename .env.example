# Proxmox connection
PROXMOX_HOST=192.168.1.100
PROXMOX_PORT=8006
PROXMOX_VERIFY_SSL=false

# Auth: API token (recommended)
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=mcp
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Auth: password (alternative)
# PROXMOX_PASSWORD=secret

# Risk tier for elevated operations:
#   read      — only read-only tools (default)
#   lifecycle — + start/stop/reboot/snapshot-create/clone
#   all       — + delete/rollback/exec
PROXMOX_RISK_LEVEL=read
